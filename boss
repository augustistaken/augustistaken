DEVICE = "cuda" if torch.cuda.is_available() else "cpu"

PAD_ID = 0
UNK_ID = 1

ACTION_KEEP = 0
ACTION_INITIAL = 1
ACTION_SHORTEN = 2
ACTION_DROP = 3

ACTION_NAMES = {
    ACTION_KEEP: "KEEP",
    ACTION_INITIAL: "INITIAL",
    ACTION_SHORTEN: "SHORTEN",
    ACTION_DROP: "DROP",
}

NAME_PARTICLES = {
    "al", "el", "bin", "binti", "ibn",
    "de", "del", "della", "da", "dos", "das",
    "di", "du", "des", "la", "le",
    "van", "von", "der", "den", "ter", "ten", "af"
}

NAME_SUFFIXES = {
    "jr", "sr", "ii", "iii", "iv", "v",
    "phd", "md", "dds", "esq"
}

NAME_PREFIXES = {
    "mr", "mrs", "ms", "miss", "dr", "prof",
    "sir", "madam", "rev", "fr", "sheikh", "shaikh", "haji"
}


def normalize_space(text: str) -> str:
    return re.sub(r"\s+", " ", (text or "").strip())


def tokenize_name(full_name: str) -> List[str]:
    return [x for x in normalize_space(full_name).split(" ") if x]


def token_features(token: str) -> List[float]:
    t = token.lower().rstrip(".")
    return [
        len(token) / 20.0,
        1.0 if token and token[0].isupper() else 0.0,
        1.0 if "-" in token else 0.0,
        1.0 if "'" in token else 0.0,
        1.0 if t in NAME_PARTICLES else 0.0,
        1.0 if t in NAME_SUFFIXES else 0.0,
        1.0 if t in NAME_PREFIXES else 0.0,
        1.0 if token.isupper() else 0.0,
    ]


def is_initial_form(src_token: str, rendered: str) -> bool:
    return bool(src_token) and rendered.strip() == f"{src_token[0].upper()}."


def fallback_shorten_candidates(token: str) -> List[Tuple[str, float]]:
    if len(token) <= 4:
        return [(token, 1.0)]
    if len(token) == 5:
        return [(token[:4] + ".", 0.7), (token[:3] + ".", 0.3)]
    return [
        (token[:4] + ".", 0.45),
        (token[:3] + ".", 0.30),
        (token[:5] + ".", 0.25),
    ]


def classify_token_action(original: str, rendered: str) -> int:
    original = original.strip()
    rendered = rendered.strip()

    if rendered == "":
        return ACTION_DROP
    if rendered == original:
        return ACTION_KEEP
    if is_initial_form(original, rendered):
        return ACTION_INITIAL
    return ACTION_SHORTEN


def render_name(tokens: List[str], rendered_tokens: List[str], split_after: int) -> Dict[str, str]:
    line1 = " ".join(x for x in rendered_tokens[: split_after + 1] if x).strip()
    line2 = " ".join(x for x in rendered_tokens[split_after + 1 :] if x).strip()
    return {"line1": line1, "line2": line2}


def valid_layout(line1: str, line2: str, max_chars_per_line: int) -> bool:
    return bool(line1) and bool(line2) and len(line1) <= max_chars_per_line and len(line2) <= max_chars_per_line


def align_tokens_to_target(full_tokens: List[str], target_tokens: List[str]) -> List[str]:
    rendered = []
    j = 0

    for tok in full_tokens:
        if j >= len(target_tokens):
            rendered.append("")
            continue

        tgt = target_tokens[j].strip()

        if tgt == tok:
            rendered.append(tgt)
            j += 1
            continue

        if is_initial_form(tok, tgt):
            rendered.append(tgt)
            j += 1
            continue

        clean_tgt = tgt.rstrip(".")
        if clean_tgt and tok.lower().startswith(clean_tgt.lower()):
            rendered.append(tgt)
            j += 1
            continue

        rendered.append("")

    return rendered


def infer_example_from_lines(full_name: str, name_line1: str, name_line2: str) -> dict:
    tokens = tokenize_name(full_name)
    line1_tokens = tokenize_name(name_line1)
    line2_tokens = tokenize_name(name_line2)
    target_tokens = line1_tokens + line2_tokens

    rendered_tokens = align_tokens_to_target(tokens, target_tokens)
    actions = [classify_token_action(src, out) for src, out in zip(tokens, rendered_tokens)]

    consumed = 0
    line1_target_count = len(line1_tokens)
    split_after = None

    for i, out_tok in enumerate(rendered_tokens):
        if out_tok:
            consumed += 1
        if consumed == line1_target_count:
            split_after = i
            break

    if split_after is None:
        split_after = max(0, len(tokens) // 2 - 1)

    return {
        "tokens": tokens,
        "actions": actions,
        "rendered_tokens": rendered_tokens,
        "split_after": split_after,
        "full_name": normalize_space(full_name),
        "name_line1": normalize_space(name_line1),
        "name_line2": normalize_space(name_line2),
    }


def custom_lines_are_logical(
    full_name: str,
    name_line1: str,
    name_line2: str,
    max_chars_per_line: int = 22,
) -> Tuple[bool, Optional[dict], str]:
    line1 = normalize_space(name_line1)
    line2 = normalize_space(name_line2)

    if not line1 or not line2:
        return False, None, "Both lines must be non-empty."

    if len(line1) > max_chars_per_line or len(line2) > max_chars_per_line:
        return False, None, f"Each line must be <= {max_chars_per_line} characters."

    ex = infer_example_from_lines(full_name, line1, line2)
    rebuilt = render_name(ex["tokens"], ex["rendered_tokens"], ex["split_after"])

    if normalize_space(rebuilt["line1"]) != line1 or normalize_space(rebuilt["line2"]) != line2:
        return False, None, "Custom lines must follow original token order and use keep/initial/shorten/drop forms only."

    if sum(1 for x in ex["rendered_tokens"] if x) < 2:
        return False, None, "Custom choice must keep at least two visible pieces of the name."

    return True, ex, "OK"


def load_examples_from_csv(path: str) -> List[dict]:
    examples = []
    with open(path, "r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        for row in reader:
            examples.append(
                infer_example_from_lines(
                    full_name=row["fullName"],
                    name_line1=row["nameLine1"],
                    name_line2=row["nameLine2"],
                )
            )
    return examples


class ShortenLexicon:
    def __init__(self):
        self.token_to_forms = defaultdict(Counter)
        self.token_pos_to_forms = defaultdict(Counter)
        self.token_action_to_forms = defaultdict(lambda: defaultdict(Counter))

    def update(self, token: str, rendered: str, position: Optional[int] = None, action: Optional[int] = None):
        if not token or not rendered:
            return
        self.token_to_forms[token][rendered] += 1
        if position is not None:
            self.token_pos_to_forms[(token, int(position))][rendered] += 1
        if action is not None:
            self.token_action_to_forms[token][int(action)][rendered] += 1

    def fit(self, examples: List[dict]) -> None:
        for ex in examples:
            for pos, (tok, act, rendered) in enumerate(zip(ex["tokens"], ex["actions"], ex["rendered_tokens"])):
                if rendered:
                    self.update(tok, rendered, position=pos, action=act)

    def get_candidates(
        self,
        token: str,
        position: Optional[int] = None,
        action: Optional[int] = None,
        topk: int = 5,
    ) -> List[Tuple[str, float]]:
        scores = Counter()

        if position is not None:
            for form, cnt in self.token_pos_to_forms.get((token, int(position)), {}).items():
                scores[form] += 3.0 * cnt

        if action is not None and token in self.token_action_to_forms:
            for form, cnt in self.token_action_to_forms[token].get(int(action), {}).items():
                scores[form] += 2.0 * cnt

        for form, cnt in self.token_to_forms.get(token, {}).items():
            scores[form] += 1.0 * cnt

        if not scores:
            if action == ACTION_KEEP:
                return [(token, 1.0)]
            if action == ACTION_INITIAL:
                return [(f"{token[0].upper()}.", 1.0)] if token else [("", 1.0)]
            if action == ACTION_DROP:
                return [("", 1.0)]
            if action == ACTION_SHORTEN:
                return fallback_shorten_candidates(token)[:topk]
            return [(token, 1.0)]

        total = sum(scores.values())
        return [(form, cnt / total) for form, cnt in scores.most_common(topk)]

    def to_dict(self) -> dict:
        return {
            "token_to_forms": {token: dict(counter) for token, counter in self.token_to_forms.items()},
            "token_pos_to_forms": [
                {"token": token, "position": pos, "forms": dict(counter)}
                for (token, pos), counter in self.token_pos_to_forms.items()
            ],
            "token_action_to_forms": {
                token: {str(action): dict(counter) for action, counter in action_map.items()}
                for token, action_map in self.token_action_to_forms.items()
            },
        }

    @classmethod
    def from_dict(cls, data: dict) -> "ShortenLexicon":
        obj = cls()
        for token, forms in data.get("token_to_forms", {}).items():
            obj.token_to_forms[token] = Counter(forms)
        for row in data.get("token_pos_to_forms", []):
            obj.token_pos_to_forms[(row["token"], int(row["position"]))] = Counter(row["forms"])
        for token, action_map in data.get("token_action_to_forms", {}).items():
            obj.token_action_to_forms[token] = defaultdict(Counter)
            for action, forms in action_map.items():
                obj.token_action_to_forms[token][int(action)] = Counter(forms)
        return obj


class TokenPositionMemory:
    def __init__(self, num_actions: int = 4):
        self.num_actions = num_actions
        self.stats = defaultdict(lambda: [1] * num_actions)

    def update(self, token: str, position: int, action: int) -> None:
        self.stats[(token.lower(), int(position))][action] += 1

    def bootstrap(self, examples: List[dict]) -> None:
        for ex in examples:
            for pos, (tok, act) in enumerate(zip(ex["tokens"], ex["actions"])):
                self.update(tok, pos, act)

    def get_log_prior(self, token: str, position: int) -> torch.Tensor:
        counts = self.stats[(token.lower(), int(position))]
        total = sum(counts)
        probs = [c / total for c in counts]
        return torch.tensor([math.log(p) for p in probs], dtype=torch.float32)

    def to_dict(self) -> dict:
        return {
            "num_actions": self.num_actions,
            "stats": [
                {"token": token, "position": pos, "counts": counts}
                for (token, pos), counts in self.stats.items()
            ],
        }

    @classmethod
    def from_dict(cls, data: dict) -> "TokenPositionMemory":
        obj = cls(num_actions=data["num_actions"])
        obj.stats = defaultdict(lambda: [1] * obj.num_actions)
        for row in data["stats"]:
            obj.stats[(row["token"], int(row["position"]))] = list(row["counts"])
        return obj


class RecentExactNameMemory:
    """
    Bounded exact-name memory.
    Keeps only the most recent N accepted examples.
    This is meant for short-term specificity, not permanent storage.
    """
    def __init__(self, max_size: int = 200):
        self.max_size = max_size
        self.rows = deque(maxlen=max_size)

    @staticmethod
    def normalize_name(full_name: str) -> str:
        return normalize_space(full_name).lower()

    def update(self, full_name: str, line1: str, line2: str) -> None:
        key = self.normalize_name(full_name)
        row = {
            "key": key,
            "full_name": normalize_space(full_name),
            "line1": normalize_space(line1),
            "line2": normalize_space(line2),
        }

        kept = [x for x in self.rows if x["key"] != key]
        self.rows = deque(kept, maxlen=self.max_size)
        self.rows.append(row)

    def get(self, full_name: str) -> Optional[dict]:
        key = self.normalize_name(full_name)
        for row in reversed(self.rows):
            if row["key"] == key:
                return row
        return None

    def to_dict(self) -> dict:
        return {
            "max_size": self.max_size,
            "rows": list(self.rows),
        }

    @classmethod
    def from_dict(cls, data: dict) -> "RecentExactNameMemory":
        obj = cls(max_size=int(data.get("max_size", 200)))
        obj.rows = deque(data.get("rows", []), maxlen=obj.max_size)
        return obj

    def as_training_examples(self) -> List[dict]:
        out = []
        for row in self.rows:
            out.append(
                infer_example_from_lines(
                    row["full_name"],
                    row["line1"],
                    row["line2"],
                )
            )
        return out


def build_token_vocab(examples: List[dict]) -> Dict[str, int]:
    vocab = {"<pad>": PAD_ID, "<unk>": UNK_ID}
    idx = 2
    for ex in examples:
        for tok in ex["tokens"]:
            if tok not in vocab:
                vocab[tok] = idx
                idx += 1
    return vocab


def build_char_vocab(examples: List[dict]) -> Dict[str, int]:
    vocab = {"<pad>": PAD_ID, "<unk>": UNK_ID}
    idx = 2
    for ex in examples:
        for tok in ex["tokens"]:
            for ch in tok:
                if ch not in vocab:
                    vocab[ch] = idx
                    idx += 1
    return vocab


class NameLayoutDataset(Dataset):
    def __init__(self, examples: List[dict], token_vocab: Dict[str, int], char_vocab: Dict[str, int]):
        self.examples = examples
        self.token_vocab = token_vocab
        self.char_vocab = char_vocab

    def __len__(self) -> int:
        return len(self.examples)

    def __getitem__(self, idx: int) -> dict:
        ex = self.examples[idx]
        tokens = ex["tokens"]
        return {
            "token_ids": [self.token_vocab.get(t, UNK_ID) for t in tokens],
            "pos_ids": list(range(len(tokens))),
            "feats": [token_features(t) for t in tokens],
            "char_ids": [[self.char_vocab.get(ch, UNK_ID) for ch in t] for t in tokens],
            "actions": ex["actions"],
            "split_after": ex["split_after"],
            "length": len(tokens),
        }


def collate_batch(batch: List[dict]) -> dict:
    batch_size = len(batch)
    max_toks = max(x["length"] for x in batch)
    max_chars = max(len(chars) for x in batch for chars in x["char_ids"])
    feat_dim = len(batch[0]["feats"][0])

    token_ids = torch.full((batch_size, max_toks), PAD_ID, dtype=torch.long)
    pos_ids = torch.zeros((batch_size, max_toks), dtype=torch.long)
    feats = torch.zeros((batch_size, max_toks, feat_dim), dtype=torch.float32)
    actions = torch.full((batch_size, max_toks), -100, dtype=torch.long)
    split_targets = torch.full((batch_size,), -100, dtype=torch.long)
    lengths = torch.zeros((batch_size,), dtype=torch.long)
    char_ids_flat = []
    char_lens_flat = []

    for i, item in enumerate(batch):
        L = item["length"]
        lengths[i] = L
        split_targets[i] = item["split_after"]
        token_ids[i, :L] = torch.tensor(item["token_ids"], dtype=torch.long)
        pos_ids[i, :L] = torch.tensor(item["pos_ids"], dtype=torch.long)
        feats[i, :L] = torch.tensor(item["feats"], dtype=torch.float32)
        actions[i, :L] = torch.tensor(item["actions"], dtype=torch.long)

        for j in range(max_toks):
            c = item["char_ids"][j] if j < L else [PAD_ID]
            char_ids_flat.append(c + [PAD_ID] * (max_chars - len(c)))
            char_lens_flat.append(len(c))

    return {
        "token_ids": token_ids,
        "pos_ids": pos_ids,
        "feats": feats,
        "actions": actions,
        "split_targets": split_targets,
        "lengths": lengths,
        "char_ids_flat": torch.tensor(char_ids_flat, dtype=torch.long),
        "char_lens_flat": torch.tensor(char_lens_flat, dtype=torch.long),
    }


class CharTokenEncoder(nn.Module):
    def __init__(self, char_vocab_size: int, char_emb_dim: int = 24, char_hidden: int = 32):
        super().__init__()
        self.emb = nn.Embedding(char_vocab_size, char_emb_dim, padding_idx=PAD_ID)
        self.gru = nn.GRU(char_emb_dim, char_hidden, batch_first=True, bidirectional=True)

    def forward(self, char_ids: torch.Tensor, char_lens: torch.Tensor) -> torch.Tensor:
        x = self.emb(char_ids)
        packed = nn.utils.rnn.pack_padded_sequence(
            x,
            char_lens.cpu(),
            batch_first=True,
            enforce_sorted=False,
        )
        _, h = self.gru(packed)
        return torch.cat([h[0], h[1]], dim=-1)


class NameShortenerModel(nn.Module):
    def __init__(
        self,
        token_vocab_size: int,
        char_vocab_size: int,
        feat_dim: int,
        num_positions: int = 16,
        token_emb_dim: int = 64,
        char_hidden: int = 32,
        pos_emb_dim: int = 16,
        hidden_dim: int = 128,
        num_actions: int = 4,
    ):
        super().__init__()
        self.token_emb = nn.Embedding(token_vocab_size, token_emb_dim, padding_idx=PAD_ID)
        self.pos_emb = nn.Embedding(num_positions, pos_emb_dim)
        self.char_encoder = CharTokenEncoder(char_vocab_size, char_hidden=char_hidden)

        input_dim = token_emb_dim + pos_emb_dim + (2 * char_hidden) + feat_dim
        self.encoder = nn.GRU(input_dim, hidden_dim, batch_first=True, bidirectional=True)
        enc_dim = hidden_dim * 2
        self.action_head = nn.Linear(enc_dim, num_actions)
        self.split_head = nn.Linear(enc_dim, 1)

    def forward(self, token_ids, pos_ids, feats, lengths, char_ids_flat, char_lens_flat):
        B, T = token_ids.shape
        tok = self.token_emb(token_ids)
        pos = self.pos_emb(pos_ids.clamp(max=self.pos_emb.num_embeddings - 1))
        ch = self.char_encoder(char_ids_flat, char_lens_flat).view(B, T, -1)

        x = torch.cat([tok, pos, ch, feats], dim=-1)
        packed = nn.utils.rnn.pack_padded_sequence(
            x,
            lengths.cpu(),
            batch_first=True,
            enforce_sorted=False,
        )
        packed_out, _ = self.encoder(packed)
        out, _ = nn.utils.rnn.pad_packed_sequence(packed_out, batch_first=True, total_length=T)

        return {
            "action_logits": self.action_head(out),
            "split_logits": self.split_head(out).squeeze(-1),
        }


def masked_split_loss(split_logits: torch.Tensor, split_targets: torch.Tensor, lengths: torch.Tensor) -> torch.Tensor:
    masked = split_logits.clone()
    B, T = split_logits.shape
    for i in range(B):
        masked[i, lengths[i].item():] = -1e9
    return F.cross_entropy(masked, split_targets)


def train_epoch(model, loader, optimizer):
    model.train()
    total = 0.0

    for batch in loader:
        batch = {k: v.to(DEVICE) for k, v in batch.items()}
        optimizer.zero_grad()

        out = model(
            batch["token_ids"],
            batch["pos_ids"],
            batch["feats"],
            batch["lengths"],
            batch["char_ids_flat"],
            batch["char_lens_flat"],
        )

        action_loss = F.cross_entropy(
            out["action_logits"].reshape(-1, out["action_logits"].size(-1)),
            batch["actions"].reshape(-1),
            ignore_index=-100,
        )
        split_loss = masked_split_loss(out["split_logits"], batch["split_targets"], batch["lengths"])
        loss = action_loss + 0.5 * split_loss

        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        optimizer.step()
        total += loss.item()

    return total / max(1, len(loader))


@torch.no_grad()
def evaluate_epoch(model, loader):
    model.eval()
    total = 0.0

    for batch in loader:
        batch = {k: v.to(DEVICE) for k, v in batch.items()}

        out = model(
            batch["token_ids"],
            batch["pos_ids"],
            batch["feats"],
            batch["lengths"],
            batch["char_ids_flat"],
            batch["char_lens_flat"],
        )

        action_loss = F.cross_entropy(
            out["action_logits"].reshape(-1, out["action_logits"].size(-1)),
            batch["actions"].reshape(-1),
            ignore_index=-100,
        )
        split_loss = masked_split_loss(out["split_logits"], batch["split_targets"], batch["lengths"])
        total += (action_loss + 0.5 * split_loss).item()

    return total / max(1, len(loader))


class NameShortenerService:
    def __init__(
        self,
        model,
        token_vocab,
        char_vocab,
        memory,
        shorten_lexicon,
        recent_exact_name_memory=None,
    ):
        self.model = model.to(DEVICE)
        self.token_vocab = token_vocab
        self.char_vocab = char_vocab
        self.memory = memory
        self.shorten_lexicon = shorten_lexicon
        self.recent_exact_name_memory = recent_exact_name_memory or RecentExactNameMemory(max_size=200)

    @classmethod
    def from_examples(cls, train_examples: List[dict]) -> "NameShortenerService":
        token_vocab = build_token_vocab(train_examples)
        char_vocab = build_char_vocab(train_examples)
        model = NameShortenerModel(
            len(token_vocab),
            len(char_vocab),
            feat_dim=len(token_features("Sample")),
        )

        memory = TokenPositionMemory()
        memory.bootstrap(train_examples)

        shorten_lexicon = ShortenLexicon()
        shorten_lexicon.fit(train_examples)

        return cls(
            model=model,
            token_vocab=token_vocab,
            char_vocab=char_vocab,
            memory=memory,
            shorten_lexicon=shorten_lexicon,
            recent_exact_name_memory=RecentExactNameMemory(max_size=200),
        )

    @classmethod
    def from_csv(cls, train_csv_path: str) -> "NameShortenerService":
        return cls.from_examples(load_examples_from_csv(train_csv_path))

    def save(self, folder: str) -> None:
        os.makedirs(folder, exist_ok=True)
        torch.save(self.model.state_dict(), os.path.join(folder, "model.pt"))

        with open(os.path.join(folder, "token_vocab.json"), "w", encoding="utf-8") as f:
            json.dump(self.token_vocab, f, ensure_ascii=False, indent=2)

        with open(os.path.join(folder, "char_vocab.json"), "w", encoding="utf-8") as f:
            json.dump(self.char_vocab, f, ensure_ascii=False, indent=2)

        with open(os.path.join(folder, "memory.json"), "w", encoding="utf-8") as f:
            json.dump(self.memory.to_dict(), f, ensure_ascii=False, indent=2)

        with open(os.path.join(folder, "shorten_lexicon.json"), "w", encoding="utf-8") as f:
            json.dump(self.shorten_lexicon.to_dict(), f, ensure_ascii=False, indent=2)

        with open(os.path.join(folder, "recent_exact_name_memory.json"), "w", encoding="utf-8") as f:
            json.dump(self.recent_exact_name_memory.to_dict(), f, ensure_ascii=False, indent=2)

    @classmethod
    def load(cls, folder: str) -> "NameShortenerService":
        with open(os.path.join(folder, "token_vocab.json"), "r", encoding="utf-8") as f:
            token_vocab = json.load(f)

        with open(os.path.join(folder, "char_vocab.json"), "r", encoding="utf-8") as f:
            char_vocab = json.load(f)

        with open(os.path.join(folder, "memory.json"), "r", encoding="utf-8") as f:
            memory = TokenPositionMemory.from_dict(json.load(f))

        with open(os.path.join(folder, "shorten_lexicon.json"), "r", encoding="utf-8") as f:
            shorten_lexicon = ShortenLexicon.from_dict(json.load(f))

        recent_path = os.path.join(folder, "recent_exact_name_memory.json")
        if os.path.exists(recent_path):
            with open(recent_path, "r", encoding="utf-8") as f:
                recent_exact_name_memory = RecentExactNameMemory.from_dict(json.load(f))
        else:
            recent_exact_name_memory = RecentExactNameMemory(max_size=200)

        model = NameShortenerModel(
            len(token_vocab),
            len(char_vocab),
            feat_dim=len(token_features("Sample")),
        )
        model.load_state_dict(torch.load(os.path.join(folder, "model.pt"), map_location=DEVICE))
        model.eval()

        return cls(
            model=model,
            token_vocab=token_vocab,
            char_vocab=char_vocab,
            memory=memory,
            shorten_lexicon=shorten_lexicon,
            recent_exact_name_memory=recent_exact_name_memory,
        )

    def fit(
        self,
        train_examples: List[dict],
        valid_examples: Optional[List[dict]] = None,
        epochs: int = 30,
        batch_size: int = 16,
        lr: float = 1e-3,
    ) -> None:
        train_ds = NameLayoutDataset(train_examples, self.token_vocab, self.char_vocab)
        train_dl = DataLoader(train_ds, batch_size=batch_size, shuffle=True, collate_fn=collate_batch)

        valid_dl = None
        if valid_examples:
            valid_ds = NameLayoutDataset(valid_examples, self.token_vocab, self.char_vocab)
            valid_dl = DataLoader(valid_ds, batch_size=batch_size, shuffle=False, collate_fn=collate_batch)

        optimizer = torch.optim.Adam(self.model.parameters(), lr=lr)

        best_state = None
        best_valid = float("inf")
        patience = 8
        no_improve = 0

        for epoch in range(1, epochs + 1):
            train_loss = train_epoch(self.model, train_dl, optimizer)

            if valid_dl:
                valid_loss = evaluate_epoch(self.model, valid_dl)
                if epoch == 1 or epoch % 5 == 0:
                    print(f"Epoch {epoch:02d} | train={train_loss:.4f} | valid={valid_loss:.4f}")

                if valid_loss < best_valid:
                    best_valid = valid_loss
                    best_state = {k: v.detach().cpu().clone() for k, v in self.model.state_dict().items()}
                    no_improve = 0
                else:
                    no_improve += 1
                    if no_improve >= patience:
                        break
            else:
                if epoch == 1 or epoch % 5 == 0:
                    print(f"Epoch {epoch:02d} | train={train_loss:.4f}")

        if best_state is not None:
            self.model.load_state_dict(best_state)

        self.model.eval()

    def _encode_single_name(self, tokens: List[str]) -> dict:
        feats = [token_features(t) for t in tokens]
        token_ids = [self.token_vocab.get(t, UNK_ID) for t in tokens]
        pos_ids = list(range(len(tokens)))
        char_ids = [[self.char_vocab.get(ch, UNK_ID) for ch in t] for t in tokens]

        max_toks = len(tokens)
        max_chars = max(len(c) for c in char_ids) if char_ids else 1
        feat_dim = len(feats[0]) if feats else len(token_features("Sample"))

        token_tensor = torch.full((1, max_toks), PAD_ID, dtype=torch.long)
        pos_tensor = torch.zeros((1, max_toks), dtype=torch.long)
        feat_tensor = torch.zeros((1, max_toks, feat_dim), dtype=torch.float32)
        char_ids_flat = []
        char_lens_flat = []

        token_tensor[0, :] = torch.tensor(token_ids, dtype=torch.long)
        pos_tensor[0, :] = torch.tensor(pos_ids, dtype=torch.long)
        feat_tensor[0, :] = torch.tensor(feats, dtype=torch.float32)

        for c in char_ids:
            char_ids_flat.append(c + [PAD_ID] * (max_chars - len(c)))
            char_lens_flat.append(len(c))

        return {
            "token_ids": token_tensor.to(DEVICE),
            "pos_ids": pos_tensor.to(DEVICE),
            "feats": feat_tensor.to(DEVICE),
            "lengths": torch.tensor([len(tokens)], dtype=torch.long).to(DEVICE),
            "char_ids_flat": torch.tensor(char_ids_flat, dtype=torch.long).to(DEVICE),
            "char_lens_flat": torch.tensor(char_lens_flat, dtype=torch.long).to(DEVICE),
        }

    def render_token_candidates(
        self,
        token: str,
        action: int,
        position: int,
        topk: int = 3,
    ) -> List[Tuple[str, float]]:
        if action == ACTION_KEEP:
            return [(token, 1.0)]
        if action == ACTION_INITIAL:
            return [(f"{token[0].upper()}.", 1.0)] if token else [("", 1.0)]
        if action == ACTION_DROP:
            return [("", 1.0)]
        if action == ACTION_SHORTEN:
            return self.shorten_lexicon.get_candidates(
                token=token,
                position=position,
                action=action,
                topk=topk,
            )
        return [(token, 1.0)]

    @torch.no_grad()
    def predict_top3(
        self,
        full_name: str,
        max_chars_per_line: int = 22,
        topk_actions_per_token: int = 3,
        topk_renderings_per_token: int = 3,
        topk_results: int = 3,
        memory_weight: float = 0.25,
    ) -> List[dict]:
        exact = self.recent_exact_name_memory.get(full_name)
        if exact is not None:
            return [{
                "line1": exact["line1"],
                "line2": exact["line2"],
                "score": 999.0,
                "actions": ["RECENT_EXACT_MEMORY"],
                "rendered_tokens": [],
                "split_after": -1,
            }]

        tokens = tokenize_name(full_name)
        if len(tokens) < 2:
            return []

        batch = self._encode_single_name(tokens)
        out = self.model(
            batch["token_ids"],
            batch["pos_ids"],
            batch["feats"],
            batch["lengths"],
            batch["char_ids_flat"],
            batch["char_lens_flat"],
        )

        action_logits = out["action_logits"][0, : len(tokens)].cpu()
        split_logits = out["split_logits"][0, : len(tokens)].cpu()

        adjusted = action_logits.clone()
        for i, tok in enumerate(tokens):
            adjusted[i] += memory_weight * self.memory.get_log_prior(tok, i)

        action_log_probs = F.log_softmax(adjusted, dim=-1)
        split_log_probs = F.log_softmax(split_logits, dim=-1)

        top_actions = []
        for i in range(len(tokens)):
            vals, idxs = torch.topk(
                action_log_probs[i],
                k=min(topk_actions_per_token, action_log_probs.size(-1)),
            )
            top_actions.append(list(zip(idxs.tolist(), vals.tolist())))

        candidates = []

        def backtrack_actions(i: int, chosen_actions: List[int], chosen_score: float):
            if i == len(tokens):
                backtrack_renderings(0, chosen_actions, [], chosen_score)
                return

            for action_id, action_score in top_actions[i]:
                backtrack_actions(i + 1, chosen_actions + [action_id], chosen_score + action_score)

        def backtrack_renderings(i: int, actions: List[int], rendered_tokens: List[str], base_score: float):
            if i == len(tokens):
                for split_after in range(len(tokens) - 1):
                    lines = render_name(tokens, rendered_tokens, split_after)
                    line1, line2 = lines["line1"], lines["line2"]

                    if not valid_layout(line1, line2, max_chars_per_line):
                        continue

                    score = base_score + split_log_probs[split_after].item()
                    score -= abs(len(line1) - len(line2)) * 0.03
                    score -= 0.08 * sum(1 for a in actions if a == ACTION_DROP)

                    candidates.append({
                        "line1": line1,
                        "line2": line2,
                        "score": round(float(score), 4),
                        "actions": [ACTION_NAMES[a] for a in actions],
                        "rendered_tokens": rendered_tokens[:],
                        "split_after": split_after,
                    })
                return

            token_cands = self.render_token_candidates(
                token=tokens[i],
                action=actions[i],
                position=i,
                topk=topk_renderings_per_token,
            )

            for rendered, render_prob in token_cands:
                render_score = math.log(max(render_prob, 1e-9))
                backtrack_renderings(
                    i + 1,
                    actions,
                    rendered_tokens + [rendered],
                    base_score + render_score,
                )

        backtrack_actions(0, [], 0.0)

        seen = set()
        results = []

        for c in sorted(candidates, key=lambda x: x["score"], reverse=True):
            key = (c["line1"], c["line2"])
            if key not in seen:
                seen.add(key)
                results.append(c)
            if len(results) >= topk_results:
                break

        return results

    def online_update_from_labeled_lines(
        self,
        full_name: str,
        name_line1: str,
        name_line2: str,
        update_model: bool = False,
        replay_examples: Optional[List[dict]] = None,
        steps: int = 0,
        lr: float = 5e-4,
    ) -> None:
        """
        Default behavior:
        - update recent exact-name memory
        - update token memory
        - update shorten lexicon
        - DO NOT update model weights

        Set update_model=True only for deliberate global adaptation.
        """
        ex = infer_example_from_lines(full_name, name_line1, name_line2)

        self.recent_exact_name_memory.update(full_name, name_line1, name_line2)

        for pos, (tok, act) in enumerate(zip(ex["tokens"], ex["actions"])):
            self.memory.update(tok, pos, act)

        for pos, (tok, act, rendered) in enumerate(zip(ex["tokens"], ex["actions"], ex["rendered_tokens"])):
            if rendered:
                self.shorten_lexicon.update(tok, rendered, position=pos, action=act)

        if not update_model or steps <= 0:
            self.model.eval()
            return

        mixed = [ex] + (replay_examples or [])
        ds = NameLayoutDataset(mixed, self.token_vocab, self.char_vocab)
        dl = DataLoader(ds, batch_size=min(8, len(ds)), shuffle=True, collate_fn=collate_batch)
        optimizer = torch.optim.Adam(self.model.parameters(), lr=lr)
        self.model.train()

        for _ in range(steps):
            for batch in dl:
                batch = {k: v.to(DEVICE) for k, v in batch.items()}
                optimizer.zero_grad()

                out = self.model(
                    batch["token_ids"],
                    batch["pos_ids"],
                    batch["feats"],
                    batch["lengths"],
                    batch["char_ids_flat"],
                    batch["char_lens_flat"],
                )

                action_loss = F.cross_entropy(
                    out["action_logits"].reshape(-1, out["action_logits"].size(-1)),
                    batch["actions"].reshape(-1),
                    ignore_index=-100,
                )
                split_loss = masked_split_loss(out["split_logits"], batch["split_targets"], batch["lengths"])
                loss = action_loss + 0.5 * split_loss

                loss.backward()
                torch.nn.utils.clip_grad_norm_(self.model.parameters(), 1.0)
                optimizer.step()

        self.model.eval()