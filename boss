def global_update_from_recent(
    self,
    base_train_examples: List[dict],
    valid_examples: Optional[List[dict]] = None,
    threshold: int = 100,
    epochs: int = 8,
    batch_size: int = 16,
    lr: float = 5e-4,
    clear_recent_after: bool = False,
) -> bool:
    """
    Explicit global update:
    - merges base + recent examples
    - rebuilds token vocab
    - rebuilds char vocab
    - rebuilds model
    - retrains everything cleanly
    """
    recent_examples = self.recent_exact_name_memory.as_training_examples()
    if len(recent_examples) < threshold:
        return False

    merged_examples = list(base_train_examples) + list(recent_examples)

    # Rebuild vocabularies so new tokens/chars become part of the model
    new_token_vocab = build_token_vocab(merged_examples)
    new_char_vocab = build_char_vocab(merged_examples)

    # Rebuild model from scratch with the new vocab sizes
    new_model = NameShortenerModel(
        token_vocab_size=len(new_token_vocab),
        char_vocab_size=len(new_char_vocab),
        feat_dim=len(token_features("Sample")),
    ).to(DEVICE)

    # Rebuild non-global helpers from merged data
    new_memory = TokenPositionMemory()
    new_memory.bootstrap(merged_examples)

    new_shorten_lexicon = ShortenLexicon()
    new_shorten_lexicon.fit(merged_examples)

    # Swap them in before training
    self.token_vocab = new_token_vocab
    self.char_vocab = new_char_vocab
    self.model = new_model
    self.memory = new_memory
    self.shorten_lexicon = new_shorten_lexicon

    # Train the rebuilt model
    self.fit(
        train_examples=merged_examples,
        valid_examples=valid_examples,
        epochs=epochs,
        batch_size=batch_size,
        lr=lr,
    )

    if clear_recent_after:
        self.recent_exact_name_memory.clear()

    return True