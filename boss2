from pathlib import Path
import json

from name_shortener_service import (
    NameShortenerService,
    load_examples_from_csv,
    custom_lines_are_logical,
    normalize_space,
)

ARTIFACT_DIR = Path("artifacts")
TRAIN_CSV = Path("train.csv")
VALID_CSV = Path("valid.csv")
META_FILE = ARTIFACT_DIR / "dataset_meta.json"


def current_dataset_meta():
    train_examples = load_examples_from_csv(str(TRAIN_CSV))
    valid_examples = load_examples_from_csv(str(VALID_CSV))
    return {
        "train_rows": len(train_examples),
        "valid_rows": len(valid_examples),
    }, train_examples, valid_examples


def artifacts_match_current_data(meta: dict) -> bool:
    if not META_FILE.exists():
        return False
    try:
        saved = json.loads(META_FILE.read_text(encoding="utf-8"))
    except Exception:
        return False
    return saved == meta


def ensure_service():
    meta, train_examples, valid_examples = current_dataset_meta()

    if ARTIFACT_DIR.exists() and (ARTIFACT_DIR / "model.pt").exists() and artifacts_match_current_data(meta):
        print("Loading existing artifacts...")
        service = NameShortenerService.load(str(ARTIFACT_DIR))
        return service, train_examples, valid_examples

    print("Training a new model...")
    service = NameShortenerService.from_examples(train_examples)
    service.fit(train_examples, valid_examples=valid_examples, epochs=35, batch_size=16, lr=1e-3)
    service.save(str(ARTIFACT_DIR))
    ARTIFACT_DIR.mkdir(exist_ok=True)
    META_FILE.write_text(json.dumps(meta, indent=2), encoding="utf-8")
    return service, train_examples, valid_examples


def print_views(views):
    print("\nCombined top suggestions:")
    for i, p in enumerate(views["combined_top3"], start=1):
        print(f"{i}. {p['line1']} | {p['line2']} | score={p['score']}")

    print("\nTop 3 line 1:")
    for i, p in enumerate(views["line1_top3"], start=1):
        print(f"{i}. {p['line1']} | score={p['score']}")

    print("\nTop 3 line 2:")
    for i, p in enumerate(views["line2_top3"], start=1):
        print(f"{i}. {p['line2']} | score={p['score']}")


def do_online_update(service, full_name, line1, line2):
    service.online_update_from_labeled_lines(
        full_name=full_name,
        name_line1=line1,
        name_line2=line2,
        update_model=False,
        replay_examples=None,
        steps=0,
        local_strength=6,
    )
    service.save(str(ARTIFACT_DIR))
    print("Updated local non-global memory and stored recent example for later global retraining.")


def maybe_do_global_update(service, train_examples, valid_examples):
    threshold = 100
    ready = service.ready_for_global_update(threshold=threshold)
    print(f"\nRecent stored examples: {service.recent_examples_count()} / {threshold}")
    if not ready:
        print("Not enough recent examples yet for global update.")
        return

    confirm = input("Run explicit global update from recent examples now? [y/N]: ").strip().lower()
    if confirm != "y":
        return

    ok = service.global_update_from_recent(
        base_train_examples=train_examples,
        valid_examples=valid_examples,
        threshold=threshold,
        epochs=8,
        batch_size=16,
        lr=5e-4,
        clear_recent_after=False,
    )
    if ok:
        service.save(str(ARTIFACT_DIR))
        print("Global update completed and saved.")
    else:
        print("Global update did not run.")


def main():
    service, train_examples, valid_examples = ensure_service()

    while True:
        print("\nMenu:")
        print("1. Predict name")
        print("2. Explicit global update from recent examples")
        print("3. Quit")
        menu = input("Choose: ").strip()

        if menu == "3":
            break

        if menu == "2":
            maybe_do_global_update(service, train_examples, valid_examples)
            continue

        if menu != "1":
            print("Unknown option.")
            continue

        full_name = input("\nFull name: ").strip()
        if not full_name:
            continue

        views = service.predict_with_views(full_name, max_chars_per_line=22)
        if not views["combined_top3"]:
            print("No valid 2-line suggestions found.")
            continue

        print_views(views)
        print("\n4. Enter a custom 2-line choice")
        choice = input("Pick 1, 2, 3, 4, or press Enter to skip update: ").strip()

        if choice in {"1", "2", "3"}:
            idx = int(choice) - 1
            if idx < len(views["combined_top3"]):
                picked = views["combined_top3"][idx]
                do_online_update(service, full_name, picked["line1"], picked["line2"])
            else:
                print("That option was not available.")

        elif choice == "4":
            custom_line1 = normalize_space(input("Custom line 1: "))
            custom_line2 = normalize_space(input("Custom line 2: "))

            ok, inferred_example, message = custom_lines_are_logical(
                full_name,
                custom_line1,
                custom_line2,
                max_chars_per_line=22,
            )
            if not ok:
                print(f"Custom choice rejected: {message}")
                continue

            print("\nCustom choice accepted.")
            print(f"line1: {custom_line1}")
            print(f"line2: {custom_line2}")
            print("Inferred rendered tokens:", inferred_example["rendered_tokens"])
            print("Inferred actions:", inferred_example["actions"])

            confirm = input("Use this for local update? [y/N]: ").strip().lower()
            if confirm == "y":
                do_online_update(service, full_name, custom_line1, custom_line2)
            else:
                print("Skipped update.")

        else:
            print("Skipped update.")


if __name__ == "__main__":
    main()